---
import '../styles/blog.css';
import JuneBot from '../components/JuneBot.astro';

interface Props {
  title: string;
  variant?: string;
  tags?: string | string[];
  image?: string;
  date: Date;
  slug: string;
  monospace_title?: boolean;
}

const { title, variant = 'post', tags, image, date, slug, monospace_title } = Astro.props;
const isWide = variant === 'post-wide';
const isMedium = variant === 'post-medium';
const isPoetry = variant === 'poetry';
const dateStr = date.toISOString();
const tagsArray = typeof tags === 'string' ? tags.split(/[,\s]+/).map(t => t.trim()).filter(Boolean) : (tags || []);
const excerpt = ''; // TODO: extract from content
const ogImage = image ? `https://june.kim/${image}` : 'https://june.kim/assets/default-icon.png';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title} | june.kim</title>
  <link rel="canonical" href={`https://june.kim/${slug}`}>

  <meta property="og:type" content="article">
  <meta property="article:published_time" content={dateStr}>
  <meta property="article:author" content="June Kim">
  {tagsArray.map(tag => <meta property="article:tag" content={tag} />)}
  <meta property="og:title" content={title}>
  <meta property="og:url" content={`https://june.kim/${slug}`}>
  <meta property="og:site_name" content="june.kim">
  <meta property="og:image" content={ogImage}>

  <meta name="twitter:card" content={image ? "summary_large_image" : "summary"}>
  <meta name="twitter:site" content="@kimjune01">
  <meta name="twitter:title" content={title}>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: title,
    url: `https://june.kim/${slug}`,
    datePublished: dateStr,
    dateModified: dateStr,
    author: { "@type": "Person", name: "June Kim", url: "https://june.kim" },
    publisher: { "@type": "Person", name: "June Kim", url: "https://june.kim" },
    license: "https://creativecommons.org/licenses/by-sa/4.0/",
    mainEntityOfPage: { "@type": "WebPage", "@id": `https://june.kim/${slug}` },
    ...(image ? { image: ogImage } : {}),
    ...(tagsArray.length > 0 ? { keywords: tagsArray.join(', ') } : {}),
  })} />

  <link rel="license" href="https://creativecommons.org/licenses/by-sa/4.0/">
  <link rel="icon" href="/images/favicon.png">
  <link rel="apple-touch-icon" href="/assets/touch-icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="//code.cdn.mozilla.net/fonts/fira.css">
  <link rel="alternate" type="application/rss+xml" href="https://june.kim/feed.xml">
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.5.0/css/font-awesome.min.css">

  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8688229960293614" crossorigin="anonymous"></script>

  {import.meta.env.PROD && (
    <Fragment>
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-CZBNWLPN64"></script>
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-CZBNWLPN64');
      </script>
    </Fragment>
  )}

</head>
<body>
  <aside class="logo">
    <a href="/">
      <img src="/images/gravatar.png" width="80" height="80" class="gravatar" alt="jk">
    </a>
    <span class="logo-prompt">Home</span>
  </aside>

  <main class={`fade-shift ${isWide ? 'wide' : isMedium ? 'medium' : ''}`} style="opacity:0.3;transform:translate(0,2px)">
    {!isPoetry && (
      <noscript>
        <style>{'article .footnotes { display: block; }'}</style>
      </noscript>
    )}

    <article class:list={[{ wide: isWide, medium: isMedium }]}>
      <div class="center">
        <h1>{monospace_title ? <code>{title}</code> : title}</h1>
      </div>
      <slot />
    </article>

    <JuneBot slug={slug} />

    {!isPoetry && (
      <a href="https://june.kim/feed.xml" class="rss-popup" id="rss-popup" title="Subscribe via RSS">
        <i class="fa fa-rss"></i>
      </a>
    )}
  </main>

  <footer class="edit-footer">
    <a href={`https://github.com/kimjune01/kimjune01.github.io/edit/master/_posts/${slug}.md`}>edit</a>
    <span class="license">
      <a rel="license" href="https://creativecommons.org/licenses/by-sa/4.0/">CC BY-SA 4.0</a>
    </span>
  </footer>

  <script>
    // RSS popup
    (function() {
      var popup = document.getElementById('rss-popup');
      if (!popup) return;
      var hasShown = false;
      var timeoutId = null;
      function isAtBottom() {
        return (window.innerHeight + window.scrollY) >= (document.body.offsetHeight - 100);
      }
      function showPopup() {
        if (!hasShown) { hasShown = true; popup.classList.add('visible'); }
      }
      window.addEventListener('scroll', function() {
        if (isAtBottom() && !hasShown) {
          if (!timeoutId) timeoutId = setTimeout(showPopup, 2000);
        } else if (!isAtBottom() && timeoutId && !hasShown) {
          clearTimeout(timeoutId); timeoutId = null;
        }
      });
    })();
  </script>
  <script async src="/assets/footnotes.js"></script>

  {isWide && (
    <Fragment>
      <script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
      <script is:inline>mermaid.initialize({startOnLoad:true});</script>
    </Fragment>
  )}

  <style is:global>
    .rss-popup {
      position: fixed; bottom: 4px; left: 10px; background: #f26522; color: white;
      width: 44px; height: 44px; border-radius: 50%; text-decoration: none;
      display: flex; align-items: center; justify-content: center; font-size: 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.2); transform: translateY(60px); opacity: 0;
      transition: transform 0.4s ease, opacity 0.4s ease; z-index: 1000;
    }
    .rss-popup:hover { background: #d55a1b; color: white; }
    .rss-popup.visible { transform: translateY(0); opacity: 1; }

    article.medium { max-width: 700px; margin: 0 auto; }
    article.medium > p, article.medium > h2, article.medium > h3, article.medium > h4,
    article.medium > ul, article.medium > ol, article.medium > blockquote, article.medium > hr,
    article.medium > div.highlighter-rouge, article.medium > .highlight {
      max-width: 500px; margin-left: auto; margin-right: auto;
    }
    article.medium > p:has(img), article.medium > figure,
    article.medium > .table-wrap, article.medium > table,
    article.medium > svg, article.medium > p:has(svg) { max-width: 100%; }
    article.wide { max-width: 90vw; margin: 0 auto; }
    article.wide > p, article.wide > h2, article.wide > h3, article.wide > h4,
    article.wide > ul, article.wide > ol, article.wide > blockquote, article.wide > hr,
    article.wide > div.highlighter-rouge, article.wide > .highlight {
      max-width: 500px; margin-left: auto; margin-right: auto;
    }
    article.wide .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; margin: 45px 0; }
    article.wide table { table-layout: auto; width: 100%; min-width: 700px; font-size: 15px; margin: 0; border-collapse: collapse; }
    article.wide table th { font-size: 14px; white-space: nowrap; position: sticky; top: 0; background: #f0f0f0; }
    article.wide table th a { color: inherit; text-decoration: none; border-bottom: 1px solid #ccc; }
    article.wide table th a:hover { border-bottom-color: #333; }
    article.wide table td { padding: 8px 10px; vertical-align: top; line-height: 1.35; }
    article.wide table td:first-child { font-weight: 600; white-space: nowrap; }
    article.wide table td.dim { opacity: 0.35; font-style: italic; }
    article.wide table td.blank {
      background: repeating-linear-gradient(
        -45deg, transparent, transparent 4px,
        rgba(0,0,0,0.03) 4px, rgba(0,0,0,0.03) 8px
      );
    }
  </style>
</body>
</html>
