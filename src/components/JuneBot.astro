---
// Inline chat with junebot at the bottom of a post.
// Lazy-mounts on first focus to keep page weight low.
interface Props { slug: string }
const { slug } = Astro.props;
const endpoint = import.meta.env.PUBLIC_JUNEBOT_URL || '';
---

{endpoint && (
  <section class="junebot" data-slug={slug} data-endpoint={endpoint}>
    <form class="junebot-form" autocomplete="off">
      <input
        type="text"
        class="junebot-input"
        placeholder="ask junebot about this post"
        aria-label="Ask junebot about this post"
        maxlength="500"
      />
      <button type="submit" class="junebot-send" aria-label="send">↵</button>
    </form>
    <div class="junebot-log" aria-live="polite"></div>
  </section>
)}

<style is:global>
  .junebot {
    max-width: 500px;
    margin: 48px auto 24px;
    padding: 16px 18px;
    border: 1px solid #ddd;
    border-radius: 10px;
    background: #fafafa;
    font-family: 'Lora', Georgia, serif;
    font-size: 15px;
    line-height: 1.5;
  }
  /* Reset blog.css defaults (big h3/p/ul margins) for everything inside the log. */
  .junebot-log, .junebot-log * {
    margin: 0;
    padding: 0;
  }
  .junebot-log { margin-top: 14px; }
  .junebot-form {
    display: flex;
    gap: 8px;
  }
  .junebot-input {
    flex: 1;
    padding: 10px 12px;
    font: inherit;
    font-size: 15px;
    border: 1px solid #ccc;
    border-radius: 6px;
    background: white;
  }
  .junebot-input:focus {
    outline: none;
    border-color: #888;
  }
  .junebot-send {
    padding: 0 14px;
    font-size: 16px;
    border: 1px solid #ccc;
    border-radius: 6px;
    background: white;
    cursor: pointer;
  }
  .junebot-send:hover { background: #f0f0f0; }
  .junebot-send:disabled { opacity: 0.4; cursor: wait; }
  .junebot-log:empty { display: none; }
  .junebot-qa .row { margin-bottom: 8px; }
  .junebot-qa .text.q { white-space: pre-wrap; }
  /* Once the answer is populated, the "A:" label is redundant — hide it. */
  .junebot-qa.answered .row.a .label { display: none; }
  /* Reserve space while streaming so the page settles once, not every token.
     Answers shorter than the reservation look slightly padded; answers longer
     expand past it. Released on `done` so final layout isn't bottom-padded. */
  .junebot-qa.streaming { min-height: 60vh; }
  .junebot-qa .row:last-of-type { margin-bottom: 0; }
  .junebot-qa .label { font-weight: 700; }
  .junebot-qa.err .text.a { color: #b91c1c; }
  .junebot-qa.err .text.a a { color: inherit; text-decoration: underline; }
  /* Answer body — tight blog-style spacing */
  .junebot-qa .text.a > p { margin-bottom: 10px; }
  .junebot-qa .text.a > p:last-child { margin-bottom: 0; }
  .junebot-qa .text.a > ul,
  .junebot-qa .text.a > ol { margin: 4px 0 10px; padding-left: 22px; list-style: revert; }
  .junebot-qa .text.a > ul:last-child,
  .junebot-qa .text.a > ol:last-child { margin-bottom: 0; }
  .junebot-qa .text.a li { margin-bottom: 2px; }
  .junebot-qa .text.a li:last-child { margin-bottom: 0; }
  .junebot-qa .text.a h3,
  .junebot-qa .text.a h4,
  .junebot-qa .text.a h5,
  .junebot-qa .text.a h6 {
    font-size: 15px; margin: 12px 0 4px; font-weight: 700;
    font-family: 'Avenir', sans-serif;
  }
  .junebot-qa .text.a h3:first-child,
  .junebot-qa .text.a h4:first-child { margin-top: 0; }
  .junebot-qa .text.a code {
    background: #eee; padding: 1px 5px; border-radius: 3px; font-size: 13px;
    font-family: 'Fira Mono', Menlo, monospace;
  }
  .junebot-qa .text.a pre {
    background: #f0f0f0; padding: 8px 10px; border-radius: 5px;
    overflow-x: auto; font-size: 13px; margin: 6px 0;
  }
  .junebot-qa .text.a pre code { background: none; padding: 0; }
  .junebot-qa .text.a a { color: #2563eb; text-decoration: underline; }
  /* Loading indicator: three-dot pulse. Shows in the A: slot until the first
     streamed token arrives, then fades out. Answers "is it working?" at the
     point of attention — no saccade, no silent gap. */
  .junebot-thinking {
    display: inline-flex;
    gap: 4px;
    align-items: center;
    padding: 4px 0;
  }
  .junebot-thinking span {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #bbb;
    opacity: 0.3;
    animation: junebot-pulse 1.2s ease-in-out infinite;
  }
  .junebot-thinking span:nth-child(2) { animation-delay: 0.18s; }
  .junebot-thinking span:nth-child(3) { animation-delay: 0.36s; }
  @keyframes junebot-pulse {
    0%, 80%, 100% { opacity: 0.3; transform: scale(0.9); }
    40% { opacity: 1; transform: scale(1.1); }
  }
  .junebot-qa .text.a {
    transition: opacity 0.2s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    .junebot-thinking span { animation: none; opacity: 0.6; }
    .junebot-qa .text.a { transition: none; }
  }
  .junebot-note {
    margin-top: 14px;
    font-size: 11px;
    color: #aaa;
    line-height: 1.45;
  }
  .junebot-note a { color: inherit; text-decoration: underline; text-decoration-color: #ccc; }
  .junebot-note a:hover { color: #777; }
</style>

<script>
  // Tiny markdown renderer. HTML-escape first so any ambient HTML in the
  // model's output is inert; then apply a small set of inline/block rules.
  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function renderMarkdown(src: string): string {
    const esc = escapeHtml(src);
    const lines = esc.split('\n');
    const out: string[] = [];
    let inUl = false;
    let inOl = false;
    let inCode = false;
    let paraBuf: string[] = [];

    const flushPara = () => {
      if (paraBuf.length === 0) return;
      out.push('<p>' + inline(paraBuf.join(' ')) + '</p>');
      paraBuf = [];
    };
    const closeLists = () => {
      if (inUl) { out.push('</ul>'); inUl = false; }
      if (inOl) { out.push('</ol>'); inOl = false; }
    };

    function inline(s: string): string {
      return s
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/(^|[^*])\*([^*\n]+)\*/g, '$1<em>$2</em>')
        .replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, '<a href="$2" rel="nofollow">$1</a>');
    }

    for (const raw of lines) {
      if (/^```/.test(raw)) {
        flushPara(); closeLists();
        if (inCode) { out.push('</code></pre>'); inCode = false; }
        else { out.push('<pre><code>'); inCode = true; }
        continue;
      }
      if (inCode) { out.push(raw); continue; }

      const line = raw.trimEnd();
      if (!line.trim()) {
        // Blank line flushes any open paragraph, but does NOT close the
        // enclosing list — blank lines between list items are a "loose"
        // list in CommonMark, not a new list.
        flushPara();
        continue;
      }

      const h = line.match(/^(#{1,4})\s+(.*)$/);
      if (h) {
        flushPara(); closeLists();
        const lvl = h[1].length + 2; // h1 maps to <h3>
        out.push(`<h${lvl}>${inline(h[2])}</h${lvl}>`);
        continue;
      }

      const ul = line.match(/^\s*[-*]\s+(.*)$/);
      if (ul) {
        flushPara();
        if (!inUl) { closeLists(); out.push('<ul>'); inUl = true; }
        out.push('<li>' + inline(ul[1]) + '</li>');
        continue;
      }

      const ol = line.match(/^\s*\d+\.\s+(.*)$/);
      if (ol) {
        flushPara();
        if (!inOl) { closeLists(); out.push('<ol>'); inOl = true; }
        out.push('<li>' + inline(ol[1]) + '</li>');
        continue;
      }

      closeLists();
      paraBuf.push(line);
    }
    flushPara(); closeLists();
    if (inCode) out.push('</code></pre>');
    // Join without newlines — a rendering container may have white-space:
    // pre-wrap, and literal \n between block tags would become visible gaps.
    return out.join('');
  }

  class JuneBot {
    el: HTMLElement;
    form: HTMLFormElement;
    input: HTMLInputElement;
    button: HTMLButtonElement;
    log: HTMLElement;
    slug: string;
    endpoint: string;

    constructor(el: HTMLElement) {
      this.el = el;
      this.slug = el.dataset.slug || '';
      this.endpoint = el.dataset.endpoint || '';
      this.form = el.querySelector('.junebot-form') as HTMLFormElement;
      this.input = el.querySelector('.junebot-input') as HTMLInputElement;
      this.button = el.querySelector('.junebot-send') as HTMLButtonElement;
      this.log = el.querySelector('.junebot-log') as HTMLElement;
      this.form.addEventListener('submit', (e) => this.onSubmit(e));
    }

    renderPair(question: string): HTMLElement {
      this.log.innerHTML =
        `<div class="junebot-qa streaming">` +
        `<div class="row"><strong class="label">Q:</strong> <span class="text q"></span></div>` +
        `<div class="row a"><strong class="label">A:</strong> <span class="text a">` +
          `<span class="junebot-thinking" aria-label="junebot is thinking">` +
            `<span></span><span></span><span></span>` +
          `</span>` +
        `</span></div>` +
        `</div>`;
      (this.log.querySelector('.text.q') as HTMLElement).textContent = question;
      return this.log.querySelector('.text.a') as HTMLElement;
    }

    appendNote(question: string) {
      const qa = this.log.querySelector('.junebot-qa');
      if (!qa || qa.querySelector('.junebot-note')) return;
      const mailto = `mailto:june@june.kim?subject=${encodeURIComponent('re: ' + this.slug)}&body=${encodeURIComponent(question + '\n\n')}`;
      const note = document.createElement('div');
      note.className = 'junebot-note';
      note.innerHTML =
        `nothing you ask is logged. <a href="${mailto}">email june directly</a> ` +
        `· <a href="https://github.com/kimjune01/june.kim/tree/master/junebot" target="_blank" rel="noopener">junebot source</a>.`;
      qa.appendChild(note);
    }

    unreserve() {
      (this.log.querySelector('.junebot-qa') as HTMLElement)?.classList.remove('streaming');
    }

    showError(answer: HTMLElement, question: string, detail: string) {
      this.unreserve();
      const subject = encodeURIComponent('junebot error');
      const body = encodeURIComponent(
        `Post: ${this.slug}\nQuestion: ${question}\nError: ${detail}`
      );
      answer.innerHTML = '';
      answer.appendChild(document.createTextNode('Something broke on my end. Try again, or '));
      const a = document.createElement('a');
      a.href = `mailto:june@june.kim?subject=${subject}&body=${body}`;
      a.textContent = 'email june@june.kim';
      answer.appendChild(a);
      answer.appendChild(document.createTextNode(` — error: ${detail}`));
      (this.log.querySelector('.junebot-qa') as HTMLElement).classList.add('err');
    }

    async onSubmit(e: Event) {
      e.preventDefault();
      const question = this.input.value.trim();
      if (!question) return;
      if (!this.endpoint) {
        this.showError(this.renderPair(question), question, 'endpoint not configured');
        return;
      }
      this.input.value = '';
      this.button.disabled = true;
      const answer = this.renderPair(question);

      try {
        const res = await fetch(this.endpoint + '/api/chat', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          // Each question is one-shot — no prior turns.
          body: JSON.stringify({ slug: this.slug, messages: [{ role: 'user', content: question }] }),
        });
        if (!res.ok || !res.body) throw new Error(`HTTP ${res.status}`);

        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buf = '';
        let full = '';
        let completed = false;
        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });
          const lines = buf.split('\n');
          buf = lines.pop() || '';
          for (const line of lines) {
            if (!line.startsWith('data: ')) continue;
            try {
              const evt = JSON.parse(line.slice(6));
              if (evt.type === 'text') {
                full += evt.text;
                // First token: atmospheric swap — brief fade replaces the
                // thinking dots with real content, drop the redundant "A:"
                // label now that the answer speaks for itself.
                if (answer.querySelector('.junebot-thinking')) {
                  answer.style.opacity = '0';
                  setTimeout(() => {
                    answer.innerHTML = renderMarkdown(full);
                    answer.style.opacity = '';
                    (this.log.querySelector('.junebot-qa') as HTMLElement)?.classList.add('answered');
                  }, 150);
                } else {
                  answer.innerHTML = renderMarkdown(full);
                }
              } else if (evt.type === 'done') {
                completed = true;
                (this.log.querySelector('.junebot-qa') as HTMLElement)?.classList.remove('streaming');
              } else if (evt.type === 'error') {
                this.showError(answer, question, evt.text || 'server error');
                return;
              }
            } catch { /* skip malformed event */ }
          }
        }
        if (completed) this.appendNote(question);
      } catch (err) {
        this.showError(answer, question, (err as Error).message || 'network error');
      } finally {
        this.button.disabled = false;
        this.input.focus();
      }
    }
  }

  document.querySelectorAll<HTMLElement>('.junebot').forEach((el) => new JuneBot(el));
</script>
