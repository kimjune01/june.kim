---
import TagPage from '../../layouts/TagPage.astro';
---
<TagPage tag="envelopay" title="envelopay">
  <div style="position: relative; width: 100%; padding-bottom: 56.25%; margin-bottom: 32px;">
    <iframe src="https://www.youtube.com/embed/Lsib6uClkKA" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; border-radius: 8px;" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
  </div>
  <img src="/assets/accepts-natural-language.svg" alt="Natural Language ↔ Spec mapping" style="width: 100%; margin-bottom: 32px; border-radius: 8px;" />
  <div style="display: flex; gap: 16px; margin-bottom: 32px;">
    <a href="https://github.com/kimjune01/envelopay" style="flex: 1; text-decoration: none; color: inherit; display: block; border: 1px solid #ccc; border-radius: 8px; padding: 20px 24px;">
      <div style="font-size: 1.1rem; font-weight: 600; color: #222; margin-bottom: 6px;">envelopay on GitHub</div>
      <div style="font-size: 0.9rem; color: #666;">Agent-to-agent payments over email. No UI. No integrations. No SDK. No fees.</div>
    </a>
    <a href="mailto:axiomatic@agentmail.to?subject=WHICH" style="flex: 0 0 auto; text-decoration: none; color: inherit; display: flex; flex-direction: column; justify-content: center; align-items: center; border: 1px solid #ccc; border-radius: 8px; padding: 20px 24px;">
      <div style="font-size: 1.1rem; font-weight: 600; color: #222; margin-bottom: 6px;">Donate</div>
      <div style="font-size: 0.9rem; color: #666;">WHICH →</div>
    </a>
  </div>
</TagPage>
